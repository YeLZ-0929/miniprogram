/* pages/book/book.wxss */
.page { padding: 32rpx 24rpx; min-height: 100vh; background: #F5F6FA; }

.section-title { font-size: 36rpx; font-weight: 500; color: #1A1A2E; margin-bottom: 24rpx; }

.book-list { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 32rpx; }

.book-card { background: #FFFFFF; border-radius: 16rpx; overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.book-card.active { border: 2rpx solid #4F80FF; }

.book-info { display: flex; align-items: center; padding: 28rpx; gap: 20rpx; }
.book-icon { font-size: 48rpx; }
.book-detail { flex: 1; }
.book-name { font-size: 30rpx; font-weight: 500; color: #1A1A2E; display: block; }
.book-role { font-size: 24rpx; color: #AAAAAA; margin-top: 4rpx; display: block; }
.check-mark { color: #4F80FF; font-size: 36rpx; font-weight: 500; }

.book-actions { border-top: 1rpx solid #F0F0F0; padding: 16rpx 28rpx; display: flex; gap: 20rpx; }
.action-btn { font-size: 26rpx; color: #4F80FF; }

.action-row { display: flex; flex-direction: column; gap: 20rpx; margin-top: 8rpx; }
.btn-create { background: #4F80FF; color: white; border: none; border-radius: 44rpx; height: 88rpx; font-size: 30rpx; font-weight: 500; }
.btn-create::after { border: none; }
.btn-join { background: transparent; color: #4F80FF; border: 2rpx solid #4F80FF; border-radius: 44rpx; height: 88rpx; font-size: 30rpx; }
.btn-join::after { border: none; }

/* 引导页 */
.onboard-hero { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0 80rpx; }
.onboard-icon { font-size: 120rpx; margin-bottom: 32rpx; }
.onboard-title { font-size: 40rpx; font-weight: 500; color: #1A1A2E; margin-bottom: 16rpx; }
.onboard-desc { font-size: 28rpx; color: #888888; text-align: center; line-height: 1.6; }
.onboard-actions { display: flex; flex-direction: column; gap: 20rpx; padding: 0 24rpx; }

/* 表单页 */
.form-page { padding: 24rpx 0; }
.back-btn { font-size: 28rpx; color: #4F80FF; margin-bottom: 40rpx; }
.form-title { font-size: 40rpx; font-weight: 500; color: #1A1A2E; margin-bottom: 48rpx; }
.form-group { margin-bottom: 40rpx; }
.label { font-size: 28rpx; color: #666666; display: block; margin-bottom: 16rpx; }
.input { width: 100%; height: 88rpx; background: #FFFFFF; border-radius: 16rpx; padding: 0 28rpx; font-size: 30rpx; box-sizing: border-box; border: 2rpx solid #E8E8E8; }

/* 弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 100; }
.modal-card { background: #FFFFFF; border-radius: 24rpx; padding: 48rpx 40rpx; width: 560rpx; display: flex; flex-direction: column; align-items: center; gap: 20rpx; }
.modal-title { font-size: 34rpx; font-weight: 500; color: #1A1A2E; }
.modal-book-name { font-size: 28rpx; color: #666666; }
.invite-code-box { background: #EEF2FF; border-radius: 16rpx; padding: 32rpx 60rpx; margin: 16rpx 0; }
.invite-code { font-size: 56rpx; font-weight: 600; color: #4F80FF; letter-spacing: 12rpx; }
.modal-tip { font-size: 24rpx; color: #AAAAAA; text-align: center; line-height: 1.6; }

/* 成员弹窗 */
.member-modal { width: 620rpx; max-height: 80vh; }
.member-list { width: 100%; max-height: 50vh; overflow-y: auto; margin-top: 12rpx; }
.member-row { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #F0F0F0; gap: 16rpx; }
.member-row:last-child { border-bottom: none; }
.member-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; flex-shrink: 0; }
.member-info { flex: 1; min-width: 0; }
.member-name-row { display: flex; align-items: center; gap: 12rpx; }
.member-nick { font-size: 28rpx; color: #1A1A2E; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.member-display { font-size: 24rpx; color: #888888; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.member-role-tag { font-size: 20rpx; padding: 2rpx 12rpx; border-radius: 8rpx; flex-shrink: 0; }
.tag-admin { background: #EEF2FF; color: #4F80FF; }
.tag-member { background: #F5F6FA; color: #AAAAAA; }
.member-joined { font-size: 22rpx; color: #CCCCCC; margin-top: 4rpx; display: block; }
.member-remove { font-size: 26rpx; color: #FF4D4F; flex-shrink: 0; padding: 8rpx 16rpx; }
.member-empty { text-align: center; padding: 40rpx 0; font-size: 26rpx; color: #AAAAAA; }
