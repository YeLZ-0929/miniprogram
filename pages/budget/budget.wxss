/* pages/budget/budget.wxss */
.container {
  padding-bottom: 40rpx;
}

/* 月份切换 */
.month-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 40rpx;
  background: #FFFFFF;
}
.month-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}
.month-arrow {
  font-size: 44rpx;
  color: #4F80FF;
  padding: 0 20rpx;
  font-weight: 300;
}
.month-arrow.disabled {
  color: #ccc;
}

/* 总览卡片 */
.overview-card {
  background: linear-gradient(135deg, #4F80FF 0%, #6B9BFF 100%);
  color: #fff;
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  padding: 32rpx;
}
.overview-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 24rpx;
}
.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.ov-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 8rpx;
}
.ov-amount {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff !important;
}
.overview-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.3);
}
.total-bar-wrap {
  height: 12rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 6rpx;
  overflow: hidden;
}
.total-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.4s ease;
}
.bar-normal { background: rgba(255,255,255,0.9); }
.bar-danger { background: #FF4D4F; }

/* 区块标题 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx 8rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #555;
}
.btn-add-budget {
  font-size: 26rpx;
  color: #4F80FF;
  background: #EEF2FF;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}

/* 预算条目 */
.budget-item {
  margin: 12rpx 24rpx;
  padding: 24rpx 28rpx;
}
.budget-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.cat-info {
  display: flex;
  align-items: center;
}
.cat-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}
.cat-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}
.budget-actions {
  display: flex;
  gap: 16rpx;
}
.action-edit {
  font-size: 24rpx;
  color: #4F80FF;
  padding: 4rpx 16rpx;
  background: #EEF2FF;
  border-radius: 12rpx;
}
.action-del {
  font-size: 24rpx;
  color: #FF4D4F;
  padding: 4rpx 16rpx;
  background: #FFF0F0;
  border-radius: 12rpx;
}

.budget-amounts {
  font-size: 26rpx;
  margin-bottom: 14rpx;
}
.actual-amount {
  font-size: 30rpx;
  font-weight: 600;
}
.budget-amount {
  font-size: 24rpx;
}

.progress-wrap {
  height: 10rpx;
  background: #F0F0F0;
  border-radius: 5rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  border-radius: 5rpx;
  transition: width 0.3s ease;
  min-width: 4rpx;
}

.over-tip {
  font-size: 22rpx;
  color: #FF4D4F;
  margin-top: 10rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}
.modal-box {
  background: #fff;
  width: 100%;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx 36rpx 60rpx;
}
.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
  text-align: center;
}
.modal-input-wrap {
  display: flex;
  align-items: center;
  background: #F5F6FA;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 88rpx;
  margin-bottom: 16rpx;
}
.modal-currency {
  font-size: 36rpx;
  color: #4F80FF;
  margin-right: 12rpx;
  font-weight: 700;
}
.modal-input {
  flex: 1;
  font-size: 34rpx;
  color: #333;
}
.modal-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  text-align: center;
  margin-bottom: 32rpx;
}
.modal-btns {
  display: flex;
}

/* 分类选择弹窗 */
.picker-box {
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}
.cat-picker-list {
  flex: 1;
  max-height: 50vh;
}
.cat-picker-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.cat-picker-item:last-child {
  border-bottom: none;
}
.cat-picker-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}
.cat-picker-name {
  font-size: 30rpx;
  color: #333;
}
