/* pages/index/index.wxss */
.page { background: #F5F6FA; min-height: 100vh; }

/* 顶部卡片 */
.header-card { background: #4F80FF; padding: 32rpx 28rpx 40rpx; }
.book-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28rpx; }
.book-name { color: #FFFFFF; font-size: 32rpx; font-weight: 500; }
.switch-hint { color: rgba(255,255,255,0.7); font-size: 24rpx; }

/* 筛选标题（从统计页跳转时） */
.filter-title { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; padding: 12rpx 20rpx; background: rgba(255,255,255,0.2); border-radius: 12rpx; }
.filter-label { font-size: 28rpx; color: #FFFFFF; font-weight: 500; }
.filter-clear { font-size: 24rpx; color: #FFD6D6; }

.month-summary { display: flex; align-items: center; background: rgba(255,255,255,0.15); border-radius: 16rpx; padding: 24rpx 0; margin-bottom: 20rpx; }
.summary-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.summary-label { font-size: 24rpx; color: rgba(255,255,255,0.8); }
.summary-amount { font-size: 36rpx; font-weight: 600; color: #FFFFFF; }
.summary-amount.expense { color: #FFD6D6; }
.summary-amount.income { color: #D6FFE8; }
.summary-divider { width: 1rpx; height: 60rpx; background: rgba(255,255,255,0.2); }

/* 快捷功能按钮 */
.quick-actions {
  display: flex;
  gap: 16rpx;
}
.quick-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 12rpx;
  padding: 16rpx 0;
}
.quick-icon { font-size: 30rpx; }
.quick-label { font-size: 26rpx; color: #fff; font-weight: 500; }

/* 筛选 */
.filter-tabs { display: flex; background: #FFFFFF; border-bottom: 1rpx solid #F0F0F0; }
.filter-tab { flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; color: #AAAAAA; }
.filter-active { color: #4F80FF; font-weight: 500; border-bottom: 4rpx solid #4F80FF; }

/* 分组列表 */
.bill-groups { padding: 16rpx 0; }

.day-group { margin-bottom: 8rpx; }
.day-header { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 28rpx; }
.day-date { font-size: 26rpx; color: #888888; }
.day-summary { display: flex; gap: 20rpx; }
.day-expense { font-size: 24rpx; color: #E24B4A; }
.day-income { font-size: 24rpx; color: #52C41A; }

.bill-card { background: #FFFFFF; margin: 0 16rpx; border-radius: 16rpx; overflow: hidden; }
.bill-row { display: flex; align-items: center; padding: 24rpx 24rpx; gap: 20rpx; border-bottom: 1rpx solid #F5F5F5; }
.bill-row:last-child { border-bottom: none; }

.bill-icon-wrap { width: 72rpx; height: 72rpx; border-radius: 18rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.bill-icon { font-size: 36rpx; }

.bill-info { flex: 1; min-width: 0; }
.bill-cat { font-size: 28rpx; color: #333333; font-weight: 500; display: block; }
.bill-note { font-size: 24rpx; color: #AAAAAA; display: block; margin-top: 4rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.bill-member { font-size: 22rpx; color: #CCCCCC; display: block; margin-top: 4rpx; }

.bill-amount { font-size: 30rpx; font-weight: 500; flex-shrink: 0; }
.amount-expense { color: #E24B4A; }
.amount-income { color: #52C41A; }
