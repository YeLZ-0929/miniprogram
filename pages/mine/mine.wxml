<!-- pages/mine/mine.wxml -->
<view class="page">
  <!-- 用户信息 -->
  <view class="user-card">
    <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" wx:if="{{userInfo && userInfo.avatarUrl}}"/>
    <view class="avatar placeholder" wx:else>👤</view>
    <view class="user-info">
      <text class="nick-name">{{displayName || (userInfo ? userInfo.nickName : '未登录')}}</text>
      <text class="book-tag">📒 {{currentBook ? currentBook.name : '未选择账本'}}</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="editNickname">
      <text class="menu-icon">✏️</text>
      <text class="menu-text">修改昵称</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goBookManage">
      <text class="menu-icon">📒</text>
      <text class="menu-text">账本管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="exportBills">
      <text class="menu-icon">📤</text>
      <text class="menu-text">导出账单</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item danger" bindtap="logout">
      <text class="menu-icon">🚪</text>
      <text class="menu-text">退出登录</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <text class="version-tip">家庭账本 v1.0.0</text>
</view>
