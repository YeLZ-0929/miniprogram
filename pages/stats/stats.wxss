/* pages/stats/stats.wxss */
.page { background: #F5F6FA; min-height: 100vh; padding-bottom: 40rpx; }

/* 月份导航 */
.month-nav { display: flex; align-items: center; justify-content: center; gap: 40rpx; padding: 28rpx 0; background: #FFFFFF; border-bottom: 1rpx solid #F0F0F0; }
.nav-arrow { font-size: 48rpx; color: #4F80FF; padding: 0 20rpx; font-weight: 300; }
.month-label { font-size: 32rpx; font-weight: 500; color: #1A1A2E; }

/* 汇总 */
.summary-card { display: flex; background: #4F80FF; padding: 32rpx 0; margin-bottom: 16rpx; }
.sum-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.sum-label { font-size: 24rpx; color: rgba(255,255,255,0.7); }
.sum-val { font-size: 32rpx; font-weight: 600; color: #FFFFFF; }
.sum-val.expense { color: #FFD6D6; }
.sum-val.income { color: #D6FFE8; }
.sum-divider { width: 1rpx; height: 60rpx; background: rgba(255,255,255,0.2); }

/* tab */
.view-tabs { display: flex; background: #FFFFFF; border-bottom: 1rpx solid #F0F0F0; margin-bottom: 16rpx; }
.view-tab { flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; color: #AAAAAA; }
.vtab-active { color: #4F80FF; font-weight: 500; border-bottom: 4rpx solid #4F80FF; }
.vtab-ai { color: #7C5CFC; flex: 0 0 auto; padding: 24rpx 24rpx; font-size: 26rpx; }

/* 饼图区域（简化版legend） */
.chart-placeholder { background: #FFFFFF; margin: 0 16rpx 16rpx; border-radius: 16rpx; padding: 28rpx; }
.pie-visual { display: flex; flex-direction: column; gap: 16rpx; }
.pie-legend-item { display: flex; align-items: center; gap: 16rpx; }
.legend-dot { width: 20rpx; height: 20rpx; border-radius: 50%; flex-shrink: 0; }
.legend-name { flex: 1; font-size: 26rpx; color: #444444; }
.legend-amount { font-size: 26rpx; color: #E24B4A; font-weight: 500; }

/* 分类列表 */
.cat-stats-list { background: #FFFFFF; margin: 0 16rpx; border-radius: 16rpx; padding: 8rpx 24rpx; }
.cat-stat-row { display: flex; align-items: center; gap: 20rpx; padding: 20rpx 0; border-bottom: 1rpx solid #F5F5F5; transition: background 0.2s; }
.cat-stat-row:last-child { border-bottom: none; }
.cat-stat-row:active { background: #F5F6FA; }
.cat-icon-wrap { width: 64rpx; height: 64rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; flex-shrink: 0; }
.cat-stat-info { flex: 1; }
.cat-stat-top { display: flex; justify-content: space-between; margin-bottom: 10rpx; }
.cat-stat-name { font-size: 28rpx; color: #333333; }
.cat-stat-amount { font-size: 28rpx; font-weight: 500; color: #E24B4A; }
.progress-bar-wrap { height: 8rpx; background: #F0F0F0; border-radius: 4rpx; margin-bottom: 8rpx; }
.progress-bar { height: 100%; border-radius: 4rpx; transition: width 0.4s; }
.cat-stat-percent { font-size: 22rpx; color: #AAAAAA; }

/* 成员统计 */
.member-stats-list { background: #FFFFFF; margin: 0 16rpx; border-radius: 16rpx; padding: 8rpx 24rpx; }
.member-stat-row { display: flex; align-items: center; gap: 20rpx; padding: 24rpx 0; border-bottom: 1rpx solid #F5F5F5; transition: background 0.2s; }
.member-stat-row:last-child { border-bottom: none; }
.member-stat-row:active { background: #F5F6FA; }
.member-avatar { width: 80rpx; height: 80rpx; border-radius: 40rpx; flex-shrink: 0; }
.member-info { flex: 1; }
.member-name { font-size: 28rpx; color: #333333; font-weight: 500; display: block; }
.member-sub { font-size: 24rpx; color: #AAAAAA; display: block; margin-top: 4rpx; }
.member-amounts { display: flex; flex-direction: column; align-items: flex-end; gap: 6rpx; }
.member-expense { font-size: 26rpx; color: #E24B4A; }
.member-income { font-size: 26rpx; color: #52C41A; }

/* 成员支出对比 */
.member-bar-section { margin-top: 20rpx; padding-top: 20rpx; border-top: 1rpx solid #F0F0F0; }
.member-bar-group { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.member-bar-label { width: 100rpx; font-size: 24rpx; color: #555; text-align: right; flex-shrink: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.member-bar-track { flex: 1; height: 20rpx; background: #F0F0F0; border-radius: 10rpx; overflow: hidden; }
.member-bar-fill { height: 100%; border-radius: 10rpx; transition: width 0.4s; }
.member-bar-val { width: 140rpx; font-size: 24rpx; color: #E24B4A; text-align: right; flex-shrink: 0; }

/* 趋势图 */
.trend-card { background: #FFFFFF; margin: 0 16rpx; border-radius: 16rpx; padding: 28rpx; }
.trend-title { font-size: 28rpx; font-weight: 500; color: #1A1A2E; display: block; margin-bottom: 32rpx; }
.bar-chart { display: flex; align-items: flex-end; justify-content: space-around; height: 200rpx; border-bottom: 1rpx solid #F0F0F0; padding-bottom: 16rpx; }
.bar-group { display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.bar-col { display: flex; gap: 6rpx; align-items: flex-end; }
.bar { width: 24rpx; border-radius: 4rpx 4rpx 0 0; min-height: 4rpx; }
.expense-bar { background: #E24B4A; opacity: 0.8; }
.income-bar { background: #52C41A; opacity: 0.8; }
.bar-label { font-size: 20rpx; color: #AAAAAA; margin-top: 8rpx; }
.bar-legend { display: flex; gap: 32rpx; justify-content: center; margin-top: 20rpx; }
.legend-item { display: flex; align-items: center; gap: 8rpx; font-size: 24rpx; color: #888888; }
.l-dot { width: 16rpx; height: 16rpx; border-radius: 4rpx; }
.expense-bg { background: #E24B4A; }
.income-bg { background: #52C41A; }

/* ===== 财务健康评分 ===== */
.health-score-card {
  display: flex;
  align-items: center;
  gap: 40rpx;
  background: #fff;
  margin: 16rpx;
  border-radius: 20rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.health-ring-wrap {
  flex-shrink: 0;
}
.health-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 10rpx solid #52C41A;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.health-score-num {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1;
}
.health-score-sub {
  font-size: 22rpx;
  color: #aaa;
}
.health-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.health-level-badge {
  display: inline-block;
  padding: 6rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  align-self: flex-start;
}
.health-month-tip {
  font-size: 24rpx;
  color: #888;
}
.health-stars {
  font-size: 28rpx;
  letter-spacing: 4rpx;
}

/* 维度列表 */
.section-title-sm {
  font-size: 28rpx;
  font-weight: 600;
  color: #444;
  display: block;
  margin-bottom: 24rpx;
}
.dim-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.dim-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0 8rpx;
}
.dim-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.dim-icon {
  font-size: 36rpx;
}
.dim-info {
  display: flex;
  flex-direction: column;
}
.dim-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.dim-desc {
  font-size: 22rpx;
  color: #aaa;
}
.dim-right {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.dim-score {
  font-size: 36rpx;
  font-weight: 700;
}
.dim-max {
  font-size: 22rpx;
  color: #aaa;
}
.dim-progress-wrap {
  height: 8rpx;
  background: #F0F0F0;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}
.dim-progress-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.4s;
}

/* 建议列表 */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.tip-item {
  background: #F5F6FA;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}
.tip-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
}
